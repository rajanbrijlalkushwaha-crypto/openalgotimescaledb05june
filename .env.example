# Copy this file to .env and fill in your values

# OpenAlgo API key (get from OpenAlgo dashboard → Profile → API Key)
OPENALGO_API_KEY=your_api_key_here

# OpenAlgo local server URLs
OPENALGO_REST_URL=http://127.0.0.1:5001
OPENALGO_WS_URL=ws://127.0.0.1:8765

# This server's port
PORT=3001

# Number of strikes above + below ATM to load
STRIKE_COUNT=20
