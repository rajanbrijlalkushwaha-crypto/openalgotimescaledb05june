# ─────────────────────────────────────────────────────────────────
#  .env.example  —  copy to .env and fill in your values
#  Never commit .env to git (it is already in .gitignore)
# ─────────────────────────────────────────────────────────────────

# ── OpenAlgo ──────────────────────────────────────────────────────
# Get from: OpenAlgo Dashboard → Profile → API Key
OPENALGO_API_KEY=your_openalgo_api_key_here

# OpenAlgo URLs — defaults work when OpenAlgo runs on same machine
OPENALGO_REST_URL=http://127.0.0.1:5001
OPENALGO_WS_URL=ws://127.0.0.1:8765

# ── soctickdata ───────────────────────────────────────────────────
PORT=3001
STRIKE_COUNT=20

# ── Database ──────────────────────────────────────────────────────
# Mac (dev/test): leave DATABASE_URL commented out
#   → automatically uses SQLite, no Docker or setup needed
#
# Linux (production): uncomment and set your TimescaleDB URL
#   → automatically uses TimescaleDB
# DATABASE_URL=postgresql://postgres:STRONG_PASSWORD@localhost:5432/soctickdata
